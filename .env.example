# ============================================
# QuantPulse Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# --- Database (TimescaleDB / PostgreSQL) ---
DATABASE_URL="postgresql://quantpulse:password@localhost:5432/quantpulse?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Backend ---
BACKEND_PORT=4000
JWT_SECRET="change-me-in-production"

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# --- Broker API (MCX Data) ---
BROKER_API_KEY=""
BROKER_API_SECRET=""
BROKER_ACCESS_TOKEN=""

# --- Global Market APIs ---
ALPHA_VANTAGE_API_KEY=""
OANDA_API_KEY=""

# --- Forex ---
USD_INR_API_KEY=""
