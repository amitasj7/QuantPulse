{
  "name": "@quantpulse/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "QuantPulse database — Prisma schema, migrations, and client",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:seed": "bunx ts-node prisma/seed.ts",
    "db:studio": "bunx prisma studio",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0"
  },
  "prisma": {
    "seed": "ts-node --compilerOptions {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
